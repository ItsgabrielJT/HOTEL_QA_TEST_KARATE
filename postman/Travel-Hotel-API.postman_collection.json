{
  "info": {
    "_postman_id": "8c960d4f-e8f8-46c6-93db-4a5ac1f2c3b6",
    "name": "Travel Hotel API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion Postman para probar la API local de Travel Hotel. Usa variables de environment para roomId, holdId, reservationId y reservationCode."
  },
  "item": [
    {
      "name": "Availability",
      "item": [
        {
          "name": "List Available Rooms",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/rooms/available?checkin={{checkin}}&checkout={{checkout}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rooms",
                "available"
              ],
              "query": [
                {
                  "key": "checkin",
                  "value": "{{checkin}}"
                },
                {
                  "key": "checkout",
                  "value": "{{checkout}}"
                }
              ]
            },
            "description": "Obtiene habitaciones disponibles para el rango de fechas configurado en el environment."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (Array.isArray(data) && data.length > 0) {",
                  "    pm.environment.set('roomId', data[0].id);",
                  "    pm.environment.set('amount', String(data[0].price_per_night));",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Holds",
      "item": [
        {
          "name": "Create Hold",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkin\": \"{{checkin}}\",\n  \"checkout\": \"{{checkout}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/rooms/{{roomId}}/hold",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rooms",
                "{{roomId}}",
                "hold"
              ]
            },
            "description": "Crea un hold temporal sobre la habitacion configurada en roomId."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.environment.set('holdId', data.id);",
                  "  pm.environment.set('roomId', data.room_id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Hold",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/holds/{{holdId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "holds",
                "{{holdId}}"
              ]
            },
            "description": "Consulta el estado del hold generado en el request anterior."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data.reservation_id) pm.environment.set('reservationId', data.reservation_id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hold_id\": \"{{holdId}}\",\n  \"amount\": {{amount}},\n  \"idempotency_key\": \"{{idempotencyKey}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments"
              ]
            },
            "description": "Procesa el pago del hold. Si el simulador responde SUCCESS, el hold deberia quedar confirmado y asociado a una reserva."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('idempotencyKey')) {",
                  "  pm.environment.set('idempotencyKey', pm.variables.replaceIn('{{$guid}}'));",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 402) {",
                  "  const data = pm.response.json();",
                  "  if (data.id) pm.environment.set('paymentId', data.id);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Reservations",
      "item": [
        {
          "name": "Get Reservation By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reservations/{{reservationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reservations",
                "{{reservationId}}"
              ]
            },
            "description": "Consulta una reserva por id. Debe usarse despues de un pago exitoso o con un reservationId conocido."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  if (data.reservation_code) pm.environment.set('reservationCode', data.reservation_code);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Reservation By Code",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/reservations?reservation_code={{reservationCode}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "reservations"
              ],
              "query": [
                {
                  "key": "reservation_code",
                  "value": "{{reservationCode}}"
                }
              ]
            },
            "description": "Consulta una reserva por el codigo visible para el usuario."
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5173/api/v1"
    }
  ]
}